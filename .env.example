# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values for local development.
# In Vercel (or any other hosting platform) set these as environment variables
# in the project settings UI.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Calendar (service account) ────────────────────────────────────────
# 1. Create a Google Cloud project and enable the Google Calendar API.
# 2. Create a service account and download its credentials.json key file.
# 3. Share EACH stylist's Google Calendar with the service account email
#    (grant "Make changes to events" / writer permission).
# 4. Set the two variables below.
#
# GOOGLE_SERVICE_ACCOUNT_EMAIL – the "client_email" value from credentials.json
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# GOOGLE_PRIVATE_KEY – the "private_key" value from credentials.json.
#
#   HOW TO SET THIS IN VERCEL:
#   Open credentials.json, copy the value of "private_key" (the string that
#   starts with -----BEGIN PRIVATE KEY----- and ends with -----END PRIVATE KEY-----\n).
#   Paste the raw JSON string value (with the literal \n sequences) directly
#   into Vercel's environment variable input field.
#   Do NOT wrap the value in extra double-quotes.
#
#   For local .env files, wrap the value in double-quotes:
#     GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── QPay (Mongolia) payment gateway ──────────────────────────────────────────
# Obtain these credentials from your QPay merchant account.
QPAY_USERNAME=your_qpay_username
QPAY_PASSWORD=your_qpay_password

# ── Server ────────────────────────────────────────────────────────────────────
# Public base URL of this deployment (used to build the QPay callback URL).
# In Vercel this is usually https://<your-project>.vercel.app
BASE_URL=https://your-project.vercel.app
